{
  "name": "Password-Manager-PRO-Dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "vscode.git"
      ]
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "docker compose up",
  "portsAttributes": {
  "8000": {
    "label": "App Preview",
    "onAutoForward": "openBrowser"
  }
}
}